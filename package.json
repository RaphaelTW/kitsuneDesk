{
  "name": "kitsunedesk",
  "version": "0.17.0",
  "description": "Aplicação desktop para pesquisar, assistir e acompanhar animes com player MPV externo estável, player embutido com fallback inteligente, perfis locais, biblioteca, backups criptografados agendados, instalação gráfica e atualização automática pelo GitHub.",
  "main": "src/main/main.js",
  "author": "Laurentino",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "npm run vendor && node scripts/prepare-dev.js && node scripts/start-electron.js",
    "start": "node scripts/prepare-dev.js && node scripts/start-electron.js",
    "vendor": "node scripts/copy-vendor.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "node scripts/build-windows.js",
    "build:win": "node scripts/build-windows.js",
    "postinstall": "npm run vendor",
    "rebuild:native": "electron-builder install-app-deps",
    "test": "node --test tests/unit/*.test.js tests/integration/*.test.js",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:integration": "node --test tests/integration/*.test.js",
    "test:e2e:electron": "node --test tests/e2e/*.test.js",
    "benchmark:startup": "node scripts/benchmark-startup.js --iterations 20",
    "benchmark:memory": "node scripts/benchmark-startup.js --iterations 5 --label memory-current --output artifacts/memory-current.json",
    "release:verify": "node scripts/verify-release-version.js",
    "release:verify-signing": "node scripts/verify-windows-signing.js",
    "release:verify-native": "node scripts/verify-native-packaging.js",
    "release:build": "node scripts/build-windows.js --publish-never",
    "release:verify-artifacts": "node scripts/verify-release-artifacts.js",
    "providers:bundle": "node scripts/verify-provider-bundles.js && node scripts/sign-provider-checksums.js",
    "release:win": "npm run release:verify && npm run providers:bundle && npm run release:build && npm run release:verify-native && npm run release:verify-signing && npm run release:verify-artifacts",
    "validate": "npm run lint && npm run format:check && npm test",
    "release:stable": "npm run validate && npm run test:e2e:electron && npm run release:verify && npm run providers:bundle && npm run release:build && npm run release:verify-native && npm run release:verify-signing && npm run release:verify-artifacts",
    "checksums:providers": "node scripts/sign-provider-checksums.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "bootstrap": "^5.3.7",
    "bootstrap-icons": "^1.13.1",
    "electron-updater": "^6.6.2",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9.30.1",
    "globals": "^16.3.0",
    "playwright": "^1.56.0",
    "prettier": "^3.6.2"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "electron-winstaller@5.4.0": true
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.11.1"
  }
}
