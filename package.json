{
  "name": "kitsunedesk",
  "version": "0.5.2",
  "description": "Aplicação desktop com GoAnime gráfico e clássico, instalação automática, fallback entre fontes e modos de áudio e correção de módulos nativos do Electron.",
  "main": "src/main/main.js",
  "author": "Raphael Laurentino da Silva",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "npm run vendor && node scripts/start-electron.js",
    "start": "node scripts/start-electron.js",
    "vendor": "node scripts/copy-vendor.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "postinstall": "npm run vendor",
    "rebuild:native": "electron-builder install-app-deps"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^12.11.1",
    "bootstrap": "^5.3.7",
    "bootstrap-icons": "^1.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.30.1",
    "globals": "^16.3.0",
    "prettier": "^3.6.2"
  },
  "build": {
    "appId": "br.com.kitsunedesk.local",
    "productName": "KitsuneDesk"
  }
}
